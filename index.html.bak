<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zen Dz Solutions | Conseil & Gestion des Entreprises</title>
    <script>
        tailwind = window.tailwind || {};
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'zen-lime': '#8BC53F',
                        'zen-purple': '#9C27B0',
                        'zen-pink': '#E91E63',
                        'zen-gold': '#D4AF37',
                        'zen-dark': '#1a1a2e',
                        'zen-gray': '#f8f9fa'
                    },
                    fontFamily: {
                        'sans': ['Outfit', 'sans-serif'],
                        'hand': ['Caveat', 'cursive'],
                    }
                }
            }
        }
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Caveat:wght@500;600;700&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'zen-lime': '#8BC53F',
                        'zen-purple': '#9C27B0',
                        'zen-pink': '#E91E63',
                        'zen-gold': '#D4AF37',
                        'zen-dark': '#1a1a2e',
                        'zen-gray': '#f8f9fa'
                    },
                    fontFamily: {
                        'sans': ['Outfit', 'sans-serif'],
                        'hand': ['Caveat', 'cursive'],
                    }
                }
            }
        }
    </script>
    <link rel="stylesheet" href="css/styles.css">
</head>
<body class="font-sans text-gray-800 antialiased overflow-x-hidden">

    <!-- Navigation -->
    <nav class="fixed w-full z-50 glass-effect border-b border-gray-100 transition-all duration-300" id="navbar">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-20">
                <div class="flex items-center space-x-3">
                    <img src="images/logo.png" alt="Zen Dz Solutions" class="w-12 h-12 rounded-xl object-cover shadow-lg">
                    <div>
                        <h1 class="font-hand text-2xl font-bold text-zen-dark">Zen Dz Solutions</h1>
                        <p class="text-xs text-zen-gold tracking-widest uppercase">Conseil & Gestion</p>
                    </div>
                </div>
                
                <div class="hidden md:flex items-center space-x-8">
                    <a href="#services" class="text-gray-600 hover:text-zen-purple transition-colors font-medium">Services</a>
                    <a href="#expertise" class="text-gray-600 hover:text-zen-purple transition-colors font-medium">Expertise</a>
                    <a href="#equipe" class="text-gray-600 hover:text-zen-purple transition-colors font-medium">Équipe</a>
                    <a href="#contact" class="px-6 py-3 gradient-bg text-white rounded-full font-medium hover:shadow-lg hover:scale-105 transition-all">
                        Prendre RDV
                    </a>
                </div>

                <button class="md:hidden text-gray-600" onclick="document.getElementById('mobile-menu').classList.toggle('hidden')">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
                </button>
            </div>
        </div>
        
        <!-- Mobile Menu -->
        <div id="mobile-menu" class="hidden md:hidden glass-effect border-t border-gray-100">
            <div class="px-4 pt-2 pb-6 space-y-2">
                <a href="#services" class="block px-3 py-2 text-gray-600 hover:text-zen-purple">Services</a>
                <a href="#expertise" class="block px-3 py-2 text-gray-600 hover:text-zen-purple">Expertise</a>
                <a href="#equipe" class="block px-3 py-2 text-gray-600 hover:text-zen-purple">Équipe</a>
                <a href="#contact" class="block px-3 py-2 text-zen-purple font-medium">Prendre RDV</a>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-gradient-to-br from-gray-50 via-white to-purple-50 pt-20">
        <!-- Hero background image -->
        <img src="images/Hero.jpg" alt="Hero image" class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-10 h-[60%] w-auto object-contain z-0 pointer-events-none">
            <img src="images/Hero2.jpg" alt="Hero image right" class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-16 h-[60%] w-auto object-contain z-0 pointer-events-none">
        <!-- Animated Blobs -->
        <div class="blob w-96 h-96 bg-zen-lime rounded-full top-0 left-0 -translate-x-1/2 -translate-y-1/2"></div>
        <div class="blob w-80 h-80 bg-zen-purple rounded-full bottom-0 right-0 translate-x-1/3 translate-y-1/3 animation-delay-2000"></div>
        <div class="blob w-64 h-64 bg-zen-pink rounded-full top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 animation-delay-4000"></div>

        <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center pb-96">
            <div class="inline-block mb-6 px-4 py-2 rounded-full bg-white/80 backdrop-blur border border-zen-lime/30 text-zen-lime font-medium text-sm tracking-wide uppercase animate-pulse">
                Expert-Comptable & Commissaire aux Comptes
            </div>
            
            <h1 class="text-5xl md:text-7xl font-bold mb-6 leading-tight">
                <span class="block text-zen-dark">Votre tranquillité</span>
                <span class="block gradient-text font-hand mt-2">est notre métier</span>
            </h1>
            
            <p class="text-xl md:text-2xl text-zen-dark max-w-3xl mx-auto mb-10 leading-relaxed">
                Zen Dz Solutions accompagne les entrepreneurs dans la gestion comptable, fiscale et sociale de leur entreprise avec<br>
                <span class="text-zen-purple font-semibold">sérénité</span> et <span class="text-zen-lime font-semibold">expertise</span>.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
                <a href="#contact" class="px-8 py-4 gradient-bg text-white rounded-full font-semibold text-lg hover:shadow-2xl hover:scale-105 transition-all flex items-center gap-2">
                    <span>Consultation gratuite</span>
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
                <a href="#services" class="px-8 py-4 bg-white text-zen-dark border-2 border-gray-200 rounded-full font-semibold text-lg hover:border-zen-purple hover:text-zen-purple transition-all">
                    Nos services
                </a>
            </div>

        </div>

        <div class="absolute bottom-28 left-1/2 -translate-x-1/2 w-full max-w-4xl px-4 grid grid-cols-2 md:grid-cols-4 gap-8">
            <div class="text-center">
                <div class="text-5xl font-bold text-zen-lime">15+</div>
                <div class="text-base text-zen-dark mt-2">Années d'expérience</div>
            </div>
            <div class="text-center">
                <div class="text-5xl font-bold text-zen-purple">500+</div>
                <div class="text-base text-zen-dark mt-2">Entreprises accompagnées</div>
            </div>
            <div class="text-center">
                <div class="text-5xl font-bold text-zen-pink">98%</div>
                <div class="text-base text-zen-dark mt-2">Clients satisfaits</div>
            </div>
            <div class="text-center">
                <div class="text-5xl font-bold text-zen-gold">24h</div>
                <div class="text-base text-zen-dark mt-2">Délai de réponse</div>
            </div>
        </div>

        <div class="absolute bottom-6 left-1/2 -translate-x-1/2 animate-bounce">
            <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
        </div>
    </section>

    <!-- Services Section -->
    <section id="services" class="py-24 bg-white relative">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-16">
                <h2 class="text-4xl font-bold text-zen-dark mb-4">Nos Expertises</h2>
                <p class="text-gray-600 max-w-2xl mx-auto">Des solutions complètes et personnalisées pour chaque étape de la vie de votre entreprise</p>
            </div>

            <div class="grid md:grid-cols-3 gap-8">
                <!-- Service 1 -->
                <div class="service-card relative bg-gray-50 rounded-2xl p-8 hover-lift overflow-hidden group">
                    <div class="w-14 h-14 rounded-xl bg-zen-lime/10 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                        <svg class="w-7 h-7 text-zen-lime" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
                    </div>
                    <h3 class="text-xl font-bold text-zen-dark mb-3">Comptabilité & Fiscalité</h3>
                    <p class="text-gray-600 mb-4">Tenue comptable, établissement des bilans, déclarations fiscales et optimisation de votre fiscalité.</p>
                    <ul class="space-y-2 text-sm text-gray-500">
                        <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-zen-lime"></span>Bilan & Compte de résultat</li>
                        <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-zen-lime"></span>Déclarations TVA</li>
                        <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-zen-lime"></span>Conseil fiscal personnalisé</li>
                    </ul>
                </div>

                <!-- Service 2 -->
                <div class="service-card relative bg-gray-50 rounded-2xl p-8 hover-lift overflow-hidden group">
                    <div class="w-14 h-14 rounded-xl bg-zen-purple/10 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                        <svg class="w-7 h-7 text-zen-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                    </div>
                    <h3 class="text-xl font-bold text-zen-dark mb-3">Gestion Sociale</h3>
                    <p class="text-gray-600 mb-4">Gestion complète de la paie, contrats de travail, et conformité sociale pour vous libérer des contraintes administratives.</p>
                    <ul class="space-y-2 text-sm text-gray-500">
                        <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-zen-purple"></span>Établissement des bulletins de paie</li>
                        <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-zen-purple"></span>Déclarations sociales</li>
                        <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-zen-purple"></span>Conseil en droit du travail</li>
                    </ul>
                </div>

                <!-- Service 3 -->
                <div class="service-card relative bg-gray-50 rounded-2xl p-8 hover-lift overflow-hidden group">
                    <div class="w-14 h-14 rounded-xl bg-zen-pink/10 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                        <svg class="w-7 h-7 text-zen-pink" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                    </div>
                    <h3 class="text-xl font-bold text-zen-dark mb-3">Conseil & Stratégie</h3>
                    <p class="text-gray-600 mb-4">Accompagnement dans la création, la croissance et la transmission de votre entreprise.</p>
                    <ul class="space-y-2 text-sm text-gray-500">
                        <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-zen-pink"></span>Création d'entreprise</li>
                        <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-zen-pink"></span>Prévisionnel & Business plan</li>
                        <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-zen-pink"></span>Transmission & Cession</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- Why Choose Us -->
    <section id="expertise" class="py-24 bg-zen-dark text-white relative overflow-hidden">
        <div class="absolute inset-0 opacity-20">
            <div class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(circle_at_50%_50%,_rgba(139,197,63,0.3),transparent_50%)]"></div>
        </div>
        
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
            <div class="grid lg:grid-cols-2 gap-16 items-center">
                <div>
                    <h2 class="text-4xl font-bold mb-6">Pourquoi choisir <span class="gradient-text font-hand">Zen Dz Solutions</span> ?</h2>
                    <p class="text-gray-300 text-lg mb-8">Nous combinons expertise technique et approche humaine pour vous offrir un service d'excellence, à la hauteur de vos enjeux.</p>
                    
                    <div class="space-y-6">
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-full bg-zen-lime/20 flex items-center justify-center flex-shrink-0">
                                <svg class="w-6 h-6 text-zen-lime" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                            </div>
                            <div>
                                <h4 class="font-semibold text-xl mb-1">Proximité & Réactivité</h4>
                                <p class="text-gray-400">Un interlocuteur dédié qui connaît votre entreprise et répond à vos questions sous 24h.</p>
                            </div>
                        </div>
                        
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-full bg-zen-purple/20 flex items-center justify-center flex-shrink-0">
                                <svg class="w-6 h-6 text-zen-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
                            </div>
                            <div>
                                <h4 class="font-semibold text-xl mb-1">Innovation Digitale</h4>
                                <p class="text-gray-400">Outils modernes et dématérialisation complète pour gagner du temps au quotidien.</p>
                            </div>
                        </div>
                        
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-full bg-zen-pink/20 flex items-center justify-center flex-shrink-0">
                                <svg class="w-6 h-6 text-zen-pink" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            </div>
                            <div>
                                <h4 class="font-semibold text-xl mb-1">Tarifs transparents</h4>
                                <p class="text-gray-400">Pas de surprises : forfaits clairs adaptés à la taille de votre structure.</p>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="relative">
                    <div class="absolute inset-0 gradient-bg rounded-3xl transform rotate-3 opacity-20"></div>
                    <div class="relative bg-gray-800 rounded-3xl p-8 border border-gray-700">
                        <div class="text-center mb-6">
                            <span class="text-zen-gold font-hand text-2xl">Témoignage client</span>
                        </div>
                        <blockquote class="text-xl italic text-gray-300 mb-6 text-center">
                            "Zen Dz Solutions a transformé notre gestion comptable. Enfin un cabinet qui parle un langage simple et propose des solutions concrètes. Je recommande vivement !"
                        </blockquote>
                        <div class="flex items-center justify-center gap-4">
                            <div class="w-12 h-12 rounded-full bg-gradient-to-br from-zen-lime to-zen-purple flex items-center justify-center text-white font-bold">
                                ML
                            </div>
                            <div class="text-left">
                                <div class="font-semibold">Marie L.</div>
                                <div class="text-sm text-gray-400">CEO, StartUp Tech</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="py-24 bg-gray-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid lg:grid-cols-2 gap-16">
                <div>
                    <h2 class="text-4xl font-bold text-zen-dark mb-6">Prenons contact</h2>
                    <p class="text-gray-600 text-lg mb-8">Discutons de vos besoins et découvrez comment nous pouvons vous accompagner dans la gestion de votre entreprise.</p>
                    
                    <div class="space-y-6">
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 rounded-full bg-white shadow-md flex items-center justify-center text-zen-purple">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                            </div>
                            <div>
                                <div class="font-semibold text-zen-dark">Adresse</div>
                                <div class="text-gray-600">123 Avenue des Champs-Élysées, 75008 Paris</div>
                            </div>
                        </div>
                        
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 rounded-full bg-white shadow-md flex items-center justify-center text-zen-lime">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                            </div>
                            <div>
                                <div class="font-semibold text-zen-dark">Email</div>
                                <div class="text-gray-600">contact@zendzsolutions.fr</div>
                            </div>
                        </div>
                        
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 rounded-full bg-white shadow-md flex items-center justify-center text-zen-pink">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                            </div>
                            <div>
                                <div class="font-semibold text-zen-dark">Téléphone</div>
                                <div class="text-gray-600">01 23 45 67 89</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-2xl shadow-xl p-8">
                    <form class="space-y-6" onsubmit="event.preventDefault(); alert('Merci pour votre message ! Nous vous contacterons sous 24h.');">
                        <div class="grid md:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Nom</label>
                                <input type="text" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-zen-purple focus:ring-2 focus:ring-zen-purple/20 outline-none transition-all" placeholder="Votre nom">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Prénom</label>
                                <input type="text" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-zen-purple focus:ring-2 focus:ring-zen-purple/20 outline-none transition-all" placeholder="Votre prénom">
                            </div>
                        </div>
                        
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Email</label>
                            <input type="email" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-zen-purple focus:ring-2 focus:ring-zen-purple/20 outline-none transition-all" placeholder="votre@email.com">
                        </div>
                        
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Sujet</label>
                            <select class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-zen-purple focus:ring-2 focus:ring-zen-purple/20 outline-none transition-all">
                                <option>Demande de devis</option>
                                <option>Création d'entreprise</option>
                                <option>Reprise de dossier</option>
                                <option>Autre demande</option>
                            </select>
                        </div>
                        
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Message</label>
                            <textarea rows="4" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-zen-purple focus:ring-2 focus:ring-zen-purple/20 outline-none transition-all" placeholder="Décrivez votre projet..."></textarea>
                        </div>
                        
                        <button type="submit" class="w-full py-4 gradient-bg text-white rounded-lg font-semibold text-lg hover:shadow-lg hover:scale-[1.02] transition-all">
                            Envoyer ma demande
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-zen-dark text-white py-12 border-t border-gray-800">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid md:grid-cols-4 gap-8 mb-8">
                <div class="col-span-2">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-10 h-10 rounded-lg gradient-bg flex items-center justify-center text-white font-bold">ZDZ</div>
                        <div>
